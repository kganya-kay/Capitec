        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>actionNames</name>
                    <valueList>
                        <valueListItems>
                            <value>Case.Conversions_Escalate_Case</value>
                            <visibilityRule>
                                <booleanFilter>1 AND 2 AND (3 OR 4)</booleanFilter>
                                <criteria>
                                    <leftValue>{!Record.Status}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>In Progress</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.Sub_Status__c}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>Active</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!$User.Profile.Name}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>Conversions Agent</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!$User.Profile.Name}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>Conversions Team Leader</rightValue>
                                </criteria>
                            </visibilityRule>
                        </valueListItems>
                        <valueListItems>
                            <value>Case.Conversions_Resolve</value>
                            <visibilityRule>
                                <booleanFilter>1 AND 5 AND (2 OR 3 OR 4)</booleanFilter>
                                <criteria>
                                    <leftValue>{!Record.Status}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>In Progress</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!$User.Profile.Name}</leftValue>
                                    <operator>EQUAL</operator>
