    </recordTypes>
    <validationRules>
        <fullName>Conversion_Case_Closed</fullName>
        <active>true</active>
        <description>Prevents the update of a case once it has been closed</description>
        <errorConditionFormula>AND(
				$Setup.Bypass_Configurations__c.Bypass_Validation_Rules__c = false,
    $Profile.Name &lt;&gt; &quot;System Administrator&quot;,
    RecordType.Name = &quot;Conversions&quot;,
    NOT(ISNEW()),
    ISPICKVAL(PRIORVALUE(Status), &quot;Closed&quot;)
)</errorConditionFormula>
        <errorMessage>A case cannot be updated once it has been closed.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Conversions_Block_Change_Status_Backward</fullName>
        <active>true</active>
        <description>This rule prevent the status of conversion cases from changing backwards</description>
        <errorConditionFormula>AND(
    NOT($Setup.Bypass_Configurations__c.Bypass_Validation_Rules__c),
	   $RecordType.Name = &quot;Conversions&quot;,
    ISCHANGED(Status),
    CASE(
        TEXT(PRIORVALUE(Status)),
        &quot;New&quot;, 1,
        &quot;In Progress&quot;, 2,
        &quot;Submitted&quot;, 3,
        &quot;Confirmed&quot;, 4,
        &quot;Closed&quot;, 5,
        0
    )
    &gt;
    CASE(
        TEXT(Status),
        &quot;New&quot;, 1,
        &quot;In Progress&quot;, 2,
        &quot;Submitted&quot;, 3,
        &quot;Confirmed&quot;, 4,
        &quot;Closed&quot;, 5,
        0
    )
)</errorConditionFormula>
        <errorMessage>You cannot move this Case back to a previous stage. Completed stages are locked to maintain process integrity.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Conversions_Cannot_Close_Case</fullName>
        <active>true</active>
        <description>Prevents a Team Leader or Manager from closing a Conversions Case.</description>
        <errorConditionFormula>AND(
				$Setup.Bypass_Configurations__c.Bypass_Validation_Rules__c = false,
    ISPICKVAL(Status, &quot;Closed&quot;),
    OR(
        $Profile.Name = &quot;Conversions Team Leader&quot;,
        $Profile.Name = &quot;Conversions Manager&quot;
    ),
    $RecordType.Name = &quot;Conversions&quot;
)</errorConditionFormula>
        <errorMessage>Only the Assigned Agent can close this case</errorMessage>
    </validationRules>
</CustomObject>
