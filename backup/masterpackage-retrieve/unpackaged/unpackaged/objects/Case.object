    <fields>
        <fullName>CON_Rag_Status__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
    CD_StrackStatus__c = &quot;Red&quot;,
    &quot;🔴 Red&quot;,
    IF(
        CD_StrackStatus__c = &quot;Amber&quot;,
        &quot;🟠 Amber&quot;,
        IF(
            CD_StrackStatus__c = &quot;Green&quot;,
            &quot;🟢 Green&quot;,
            &quot;&quot;
        )
    )
)</formula>
        <label>Rag Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
