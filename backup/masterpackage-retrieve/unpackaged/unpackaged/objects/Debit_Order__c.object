    <fields>
        <fullName>TECH_CB_To_Email__c</fullName>
        <formula>IF(
    TEXT(Debit_Order_Initiator__r.Preferred_Comms__c) = &apos;CB To Email&apos;,
    TRUE,
    FALSE
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>CB To Email?</label>
