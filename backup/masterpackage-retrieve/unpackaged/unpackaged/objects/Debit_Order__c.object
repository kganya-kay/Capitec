    <label>Debit Order</label>
    <nameField>
        <label>DO Reference Number</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Debit Orders</pluralLabel>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Amount_cannot_be_negative</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
   NOT(ISBLANK(Amount__c)),  
   Amount__c &lt;= 0
)</errorConditionFormula>
        <errorMessage>Amount must be greater than zero.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Confirmed_Cause_Code_Rule</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
    NOT(ISNEW()), 
    ISPICKVAL(Case__r.Status, &quot;Submitted&quot;),
    ISBLANK(TEXT(Confirmation_Cause_Code__c))
)</errorConditionFormula>
        <errorMessage>Please enter Confirmation Cause Code before saving.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Other_Debit_Issue_Field_is_blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
				NOT($Setup.Bypass_Configurations__c.Bypass_Validation_Rules__c),
    INCLUDES(DO_Issue__c, &quot;Other&quot;),
    ISBLANK(Other_Debit_Order_Issue__c)
)</errorConditionFormula>
        <errorMessage>Please specify the Other Debit Order Issue.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Submitted_and_Withdrawn_Cause_Code_Rule</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
    NOT(ISNEW()), 
    ISPICKVAL(Case__r.Status, &quot;In Progress&quot;),
    ISBLANK(TEXT(Submitted_Cause_Code__c)),
    ISBLANK(TEXT(Withdrawn_Cause_Code__c))
)</errorConditionFormula>
        <errorMessage>Please enter Submitted Cause Code OR Withdrawn Cause Code before saving.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
