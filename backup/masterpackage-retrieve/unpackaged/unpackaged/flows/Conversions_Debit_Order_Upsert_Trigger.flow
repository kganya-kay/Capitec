<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Logics_To_Execute</name>
        <label>Logics To Execute</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Insert_Logics</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Publish_Create_Event</targetReference>
            </connector>
            <label>Insert Logics</label>
        </rules>
        <rules>
            <name>Update_Logics</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Publish_Update_Event</targetReference>
            </connector>
            <label>Update Logics</label>
        </rules>
    </decisions>
    <description>COCONV-1735 -Optimisation
COCONV-2094 - Publish Edit &amp; Create Event
COCONV-1738 - Re Activate Case if there are activities on the DO
COCONV-1938 - Track Debit Orders To Auto Close Case</description>
    <environments>Default</environments>
    <interviewLabel>Conversions - Debit Order Upsert Trigger {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Conversions - Debit Order Upsert Trigger</label>
