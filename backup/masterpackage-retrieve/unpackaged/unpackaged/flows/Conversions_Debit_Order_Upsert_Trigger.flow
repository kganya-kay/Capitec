    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Logics_To_Execute</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Configurations__c.Bypass_Flows__c} = false</filterFormula>
        <object>Debit_Order__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <description>Conditions to verify if the case record needs to be closed</description>
        <name>Conditions_To_Auto_Close_Case</name>
        <label>Conditions To Auto Close Case</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Copy_1_of_Reactivate_Case_Subflow</targetReference>
        </connector>
        <flowName>Conversions_Auto_Close_Case</flowName>
        <inputAssignments>
            <name>caseRecord</name>
            <value>
                <elementReference>CaseRecord</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>ConversionRecord</name>
            <value>
                <elementReference>Copy_1_of_Get_Conversion_Record</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>DebitOrderRecord</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <description>COCONV-1738: Reactivate Case if there are activities on DO level</description>
        <name>Copy_1_of_Reactivate_Case_Subflow</name>
