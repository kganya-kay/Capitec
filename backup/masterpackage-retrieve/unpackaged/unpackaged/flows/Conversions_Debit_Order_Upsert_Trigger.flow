            </value>
        </inputAssignments>
    </subflows>
    <subflows>
        <description>Subflow with conditions to verify if the Case Record needs to be updated to Confirmed</description>
        <name>Update_Case_To_Confirm_Subflow</name>
        <label>Update Case To Confirm Subflow</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>Conversions_Update_Case_To_Confirm_Subflow</flowName>
        <inputAssignments>
            <name>CaseRecord</name>
            <value>
                <elementReference>Get_Case_Record</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
    <subflows>
        <description>Subflow with conditions to verify if the Conversion Object need to be updated to Future Dated</description>
        <name>Update_Case_To_FD_subflow</name>
        <label>Update Case To FD subflow</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Reactivate_Case_Subflow</targetReference>
        </connector>
        <flowName>Conversions_Mark_Case_As_Future_Dated_Subflow</flowName>
        <inputAssignments>
            <name>ConversionRecord</name>
            <value>
