    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Conversion_Case</targetReference>
        </connector>
        <filterFormula>AND
({!$Record.RecordType.DeveloperName} =&apos;Conversions&apos;,
{!$Setup.Bypass_Configurations__c.Bypass_Flows__c} = false)</filterFormula>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <name>Case_Auto_Close</name>
            <connector>
                <targetReference>Verify_SLA_Date</targetReference>
            </connector>
            <label>Case Auto Close</label>
            <offsetNumber>0</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <recordField>SLA_Time__c</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
